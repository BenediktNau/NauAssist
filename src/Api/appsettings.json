{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "NauAssist": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "Paths": {
    "CoreRoot": "src",
    "ExtensionsRoot": "extensions",
    "DataRoot": "data",
    "LogsRoot": "data/logs",
    "ModelsRoot": "models"
  },
  "Llm": {
    "Model": "gemma4:e4b",
    "Endpoint": "http://host.docker.internal:11434",
    "Temperature": 0.7,
    "MaxTokens": 2048,
    "TimeoutSeconds": 60,
    "Retries": 3
  },
  "Memory": {
    "DatabaseFile": "memory.db",
    "Layer4FtsEnabled": true
  },
  "Scheduler": {
    "ReflectionInterval": "00:05:00",
    "QuietHoursStart": "22:00",
    "QuietHoursEnd": "07:00"
  },
  "Sources": {
    "Mailboxes": [],
    "CalendarEndpoints": [],
    "ChatChannels": []
  },
  "Voice": {
    "WhisperModelFile": "ggml-base.bin",
    "PiperVoice": "de_DE-thorsten-medium",
    "VadThreshold": 0.5
  }
}
