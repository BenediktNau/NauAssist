{
  "name": "nauassist-wa",
  "version": "0.1.0",
  "private": true,
  "description": "NauAssist WhatsApp-Sidecar (Baileys) — hält die WA-Session und puffert Nachrichten für den autonomen Agenten.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
