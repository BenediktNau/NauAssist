    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "better-sqlite3": "^11.10.0",
    "fastify": "^5.8.5",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.1",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22"
  }
}
