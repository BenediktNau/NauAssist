# NauAssist — Beispiel-Environment
#
# Diese Datei nach .env kopieren und für die lokale / Compose-Inbetriebnahme
# anpassen. .env ist gitignored — keine echten Secrets in .env.example.
#
# Konvention: doppelter Unterstrich entspricht der Section-Verschachtelung
# in appsettings.json. "Llm__Endpoint" überschreibt also { "Llm": { "Endpoint": ... } }.

# Wo die Solution gemountet ist (Container) bzw. die Repo-Wurzel (Dev).
# Im Container vom Compose-Setup gesetzt; lokal kann es leer bleiben — der
# PathResolver findet die Solution dann über die NauAssist.slnx aufwärts.
Paths__BaseDirectory=

# LLM (Ollama auf dem Host)
Llm__Endpoint=http://host.docker.internal:11434
Llm__Model=gemma4:e4b

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:8080

# Platzhalter für spätere Etappen (nichts hier eintragen, was wirklich geheim ist)
# IMAP_HOST=
# IMAP_USER=
# IMAP_PASSWORD=
# CALDAV_URL=
# CALDAV_USER=
# CALDAV_PASSWORD=
